# Smelt Service Images
#
# Override these to use different registries, images, or tags.
# Example: PIRI_IMAGE=ghcr.io/storacha/piri:v1.2.3
#
# These variables are automatically loaded by Docker Compose when running
# from the project root directory.

# Storacha services
PIRI_IMAGE=forreststoracha/piri:dev
GUPPY_IMAGE=forreststoracha/guppy:dev
DELEGATOR_IMAGE=forreststoracha/delegator:dev
INDEXER_IMAGE=forreststoracha/indexer:dev
IPNI_IMAGE=forreststoracha/storetheindex:dev
SIGNER_IMAGE=forreststoracha/signer:dev
UPLOAD_IMAGE=ghcr.io/storacha/sprue:main

# Infrastructure
BLOCKCHAIN_IMAGE=ghcr.io/storacha/filecoin-localdev:f2acf8a
