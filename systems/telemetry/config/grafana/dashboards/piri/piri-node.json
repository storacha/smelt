{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["smelt", "piri", "postgres"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Piri Storage Node",
  "uid": "piri-node",
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "DS",
        "type": "datasource",
        "label": "Node",
        "description": "Pick which piri node's postgres to view",
        "query": "grafana-postgresql-datasource",
        "regex": "/^Piri \\d+$/",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    { "type": "row", "id": 1, "title": "Overview",
      "collapsed": false, "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "panels": [] },

    { "type": "stat", "id": 10, "title": "Live Scheduler Tasks",
      "description": "Rows currently in scheduler.task (not yet moved to task_history).",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) AS value FROM scheduler.task" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 200 }] } }, "overrides": [] } },

    { "type": "stat", "id": 11, "title": "Task Success % (1h)",
      "description": "Percent of task_history rows with result=true in the last hour.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT round(100.0 * count(*) FILTER (WHERE result) / NULLIF(count(*),0), 1) AS value FROM scheduler.task_history WHERE work_end >= now() - interval '1 hour'" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 80 }, { "color": "green", "value": 95 }] } }, "overrides": [] } },

    { "type": "stat", "id": 12, "title": "Parked Pieces",
      "description": "count(*) and sum(piece_raw_size) in scheduler.parked_pieces.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) AS pieces, coalesce(sum(piece_raw_size),0) AS bytes FROM scheduler.parked_pieces" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [ { "matcher": { "id": "byName", "options": "bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] } ] } },

    { "type": "stat", "id": 13, "title": "PDP Proof Sets",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) AS value FROM scheduler.pdp_proof_sets" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] } },

    { "type": "stat", "id": 14, "title": "Dead Queue Total",
      "description": "Sum of permanently-failed jobs across all four dead tables.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT (SELECT count(*) FROM aggregator.jobqueue_dead) + (SELECT count(*) FROM replicator.jobqueue_dead) + (SELECT count(*) FROM egress_tracker.jobqueue_dead) + (SELECT count(*) FROM aggregator.job_dead) AS value" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] } }, "overrides": [] } },

    { "type": "stat", "id": 15, "title": "Pending TX Confirmations",
      "description": "message_waits_eth rows with tx_success IS NULL (still waiting for the chain).",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) AS value FROM scheduler.message_waits_eth WHERE tx_success IS NULL" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }] } }, "overrides": [] } },

    { "type": "row", "id": 2, "title": "Scheduler — Task Engine",
      "collapsed": false, "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "panels": [] },

    { "type": "timeseries", "id": 20, "title": "Task Completion Rate by Name",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "time_series", "rawSql": "SELECT $__timeGroupAlias(work_end, $__interval), name, count(*) FROM scheduler.task_history WHERE $__timeFilter(work_end) GROUP BY 1, 2 ORDER BY 1" } ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } }, "overrides": [] } },

    { "type": "timeseries", "id": 21, "title": "Task Success vs Failure",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "time_series", "rawSql": "SELECT $__timeGroupAlias(work_end, $__interval), count(*) FILTER (WHERE result) AS success, count(*) FILTER (WHERE NOT result) AS failed FROM scheduler.task_history WHERE $__timeFilter(work_end) GROUP BY 1 ORDER BY 1" } ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [ { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] } ] } },

    { "type": "timeseries", "id": 22, "title": "Task Duration — P50 / P95 / max",
      "description": "Seconds between work_start and work_end from scheduler.task_history.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "time_series", "rawSql": "SELECT $__timeGroupAlias(work_end, $__interval), percentile_cont(0.50) WITHIN GROUP (ORDER BY extract(epoch from work_end - work_start)) AS p50, percentile_cont(0.95) WITHIN GROUP (ORDER BY extract(epoch from work_end - work_start)) AS p95, max(extract(epoch from work_end - work_start)) AS max FROM scheduler.task_history WHERE $__timeFilter(work_end) GROUP BY 1 ORDER BY 1" } ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 5 } }, "overrides": [] } },

    { "type": "table", "id": 23, "title": "Live Tasks",
      "description": "Rows currently in scheduler.task with age since posted_time.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false, "reducer": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT id, name, session_id, retries, posted_time, extract(epoch from now() - posted_time)::int AS age_seconds FROM scheduler.task ORDER BY posted_time DESC LIMIT 50" } ],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "age_seconds" }, "properties": [{ "id": "unit", "value": "s" }] } ] } },

    { "type": "table", "id": 24, "title": "Recent Task Failures",
      "description": "scheduler.task_history WHERE result = false, most recent 50.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 6 },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false, "reducer": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT task_id, name, posted, work_end, err, completed_by_session_id FROM scheduler.task_history WHERE NOT result AND $__timeFilter(work_end) ORDER BY work_end DESC LIMIT 50" } ],
      "fieldConfig": { "defaults": {}, "overrides": [] } },

    { "type": "row", "id": 3, "title": "Scheduler — PDP & Parked Pieces",
      "collapsed": false, "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 }, "panels": [] },

    { "type": "table", "id": 30, "title": "PDP Proof Sets",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 29, "w": 14, "h": 6 },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false, "reducer": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT id, service, init_ready, proving_period, challenge_window, prove_at_epoch, prev_challenge_request_epoch FROM scheduler.pdp_proof_sets ORDER BY id" } ],
      "fieldConfig": { "defaults": {}, "overrides": [] } },

    { "type": "stat", "id": 31, "title": "Parked Pieces — Stats",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 14, "y": 29, "w": 10, "h": 6 },
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) AS pieces, count(*) FILTER (WHERE complete) AS complete, count(*) FILTER (WHERE long_term) AS long_term, coalesce(sum(piece_raw_size),0) AS raw_bytes, coalesce(sum(piece_padded_size),0) AS padded_bytes FROM scheduler.parked_pieces" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": ".*bytes" }, "properties": [{ "id": "unit", "value": "bytes" }] } ] } },

    { "type": "timeseries", "id": 32, "title": "Pieces Added Over Time",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 35, "w": 12, "h": 6 },
      "options": { "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "time_series", "rawSql": "SELECT $__timeGroupAlias(created_at, $__interval), count(*) AS pieces FROM scheduler.parked_pieces WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1" } ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [] } },

    { "type": "table", "id": 33, "title": "Top Parked Pieces by Size",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 12, "y": 35, "w": 12, "h": 6 },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false, "reducer": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT piece_cid, piece_raw_size, piece_padded_size, complete, long_term, created_at FROM scheduler.parked_pieces ORDER BY piece_raw_size DESC LIMIT 20" } ],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byRegexp", "options": "piece_(raw|padded)_size" }, "properties": [{ "id": "unit", "value": "bytes" }] } ] } },

    { "type": "row", "id": 4, "title": "Scheduler — Blockchain (Ethereum / Filecoin)",
      "collapsed": false, "gridPos": { "x": 0, "y": 41, "w": 24, "h": 1 }, "panels": [] },

    { "type": "stat", "id": 40, "title": "TX Wait States",
      "description": "message_waits_eth grouped by confirmation state.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 42, "w": 8, "h": 5 },
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) FILTER (WHERE tx_success IS NULL) AS pending, count(*) FILTER (WHERE tx_success = true) AS confirmed, count(*) FILTER (WHERE tx_success = false) AS failed FROM scheduler.message_waits_eth" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [ { "matcher": { "id": "byName", "options": "pending" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }, { "matcher": { "id": "byName", "options": "confirmed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] } ] } },

    { "type": "timeseries", "id": 41, "title": "TX Submissions (sent / failed)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 8, "y": 42, "w": 16, "h": 5 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "time_series", "rawSql": "SELECT $__timeGroupAlias(send_time, $__interval), count(*) FILTER (WHERE send_success) AS sent, count(*) FILTER (WHERE NOT send_success) AS failed FROM scheduler.message_sends_eth WHERE $__timeFilter(send_time) GROUP BY 1 ORDER BY 1" } ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [ { "matcher": { "id": "byName", "options": "sent" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] } ] } },

    { "type": "table", "id": 42, "title": "Recent Failed TX Sends",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 6 },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false, "reducer": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT send_task_id, from_address, to_address, send_reason, send_time, send_error FROM scheduler.message_sends_eth WHERE send_success = false ORDER BY send_time DESC NULLS LAST LIMIT 20" } ],
      "fieldConfig": { "defaults": {}, "overrides": [] } },

    { "type": "row", "id": 5, "title": "Aggregator (base jobqueue + deduping engine)",
      "collapsed": false, "gridPos": { "x": 0, "y": 53, "w": 24, "h": 1 }, "panels": [] },

    { "type": "stat", "id": 50, "title": "aggregator.jobqueue Depth",
      "description": "pending = received=0; in_flight = received>0 AND timeout>now; zombies = received>0 AND timeout<=now (lease expired, will re-lease); dead = aggregator.jobqueue_dead rows.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 54, "w": 8, "h": 5 },
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT count(*) FILTER (WHERE received = 0) AS pending, count(*) FILTER (WHERE received > 0 AND timeout > now()) AS in_flight, count(*) FILTER (WHERE received > 0 AND timeout <= now()) AS zombies, (SELECT count(*) FROM aggregator.jobqueue_dead) AS dead FROM aggregator.jobqueue" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [ { "matcher": { "id": "byName", "options": "pending" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }, { "matcher": { "id": "byName", "options": "in_flight" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "zombies" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }, { "matcher": { "id": "byName", "options": "dead" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] } ] } },

    { "type": "stat", "id": 51, "title": "aggregator Dedupe Engine",
      "description": "live = aggregator.jobs; done = aggregator.job_done (completed, retained for dedup); dead = aggregator.job_dead; namespaces = aggregator.job_ns.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 8, "y": 54, "w": 8, "h": 5 },
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT (SELECT count(*) FROM aggregator.jobs) AS live, (SELECT count(*) FROM aggregator.job_done) AS done, (SELECT count(*) FROM aggregator.job_dead) AS dead, (SELECT count(*) FROM aggregator.job_ns) AS namespaces" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [ { "matcher": { "id": "byName", "options": "dead" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }, { "matcher": { "id": "byName", "options": "done" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] } ] } },

    { "type": "table", "id": 52, "title": "aggregator Top Sub-Queues by Depth",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 16, "y": 54, "w": 8, "h": 5 },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false, "reducer": ["sum"], "fields": "" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" }, "format": "table", "rawSql": "SELECT queue, count(*) AS depth FROM aggregator.jobqueue GROUP BY queue ORDER BY depth DESC" } ],
      "fieldConfig": { "defaults": {}, "overrides": [] } },

    { "type": "timeseries", "id": 53, "title": "aggregator Dedupe Completion Rate",
      "description": "Throughput of aggregator.job_done, split by status code.",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "${DS}" },
      "gridPos": { "x": 0, "y": 59, "w": 8, "h": 5 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
